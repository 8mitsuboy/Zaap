---
interface Props {
  url: string;
  title: string;
  pubDate?: string;
  tags?: string[];
  isLast?: boolean;
}
const { url, title, pubDate, tags, isLast = false } = Astro.props;

const categoryColorMap: Record<string, { dot: string; border: string; bg: string; text: string }> = {
  Astro:    { dot: "#4a90a4", border: "#80c0d4", bg: "#4a90a420", text: "#80c0d4" },
  Blender:  { dot: "#a46a4a", border: "#d4a080", bg: "#a46a4a20", text: "#d4a080" },
  React:    { dot: "#4a7aa4", border: "#80aad4", bg: "#4a7aa420", text: "#80aad4" },
  "Next.js":{ dot: "#6060c0", border: "#9090e0", bg: "#6060c020", text: "#9090e0" },
  AI:       { dot: "#7a4aa4", border: "#aa80d4", bg: "#7a4aa420", text: "#aa80d4" },
  Flutter:  { dot: "#4aa47a", border: "#80d4aa", bg: "#4aa47a20", text: "#80d4aa" },
};

const fallbackColor = { dot: "#606080", border: "#9090a0", bg: "#60608020", text: "#9090a0" };

const primaryTag = tags?.[0] ?? "";
const color = categoryColorMap[primaryTag] ?? fallbackColor;

const displayDate = pubDate
  ? new Date(pubDate).toLocaleDateString("ja-JP", {
      month: "2-digit",
      day: "2-digit",
    })
  : null;
---

<div class="flex items-stretch gap-3">
  <!-- ドット + 縦線 -->
  <div class="flex flex-col items-center flex-shrink-0 w-3">
    <div class="h-4 flex-shrink-0"></div>
    <div
      class="w-3 h-3 rounded-full flex-shrink-0 z-10"
      style={`background: ${color.dot}; border: 2px solid ${color.border};`}
    ></div>
    {!isLast && (
      <div class="w-px flex-1 mt-1" style="background: #2a2a50;"></div>
    )}
  </div>

  <!-- エントリ内容 -->
  <a
    href={url}
    class={`flex-1 py-3 no-underline group ${!isLast ? "border-b border-bzine-light-border dark:border-bzine-border" : ""}`}
  >
    <p class="font-bold text-sm text-bzine-light-text dark:text-bzine-text group-hover:text-bzine-accent transition-colors mb-1 leading-snug">
      {title}
    </p>
    <div class="flex items-center gap-2 flex-wrap">
      {displayDate && (
        <time class="text-xs font-mono text-bzine-light-text-muted dark:text-bzine-text-muted">
          {displayDate}
        </time>
      )}
      {tags && tags.map((tag) => (
        <span
          class="text-xs px-1.5 py-0.5 rounded"
          style={`background: ${color.bg}; color: ${color.text};`}
        >
          {tag}
        </span>
      ))}
    </div>
  </a>
</div>
